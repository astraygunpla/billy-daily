# ─── Discord ──────────────────────────────────────────────────────────────────
# Token do bot — Discord Developer Portal → seu app → Bot → Token
DISCORD_TOKEN=

# ID do servidor onde o bot vai operar
# Ative o Modo Desenvolvedor (Configurações → Avançado) e clique com botão
# direito no ícone do servidor → Copiar ID do servidor
DISCORD_GUILD_ID=

# ID do cargo cujos membros recebem a daily por DM
# Configurações do servidor → Cargos → botão direito no cargo → Copiar ID do cargo
DISCORD_ROLE_ID=

# Seu ID de usuário no Discord (único autorizado a usar os comandos !...)
# Botão direito no seu nome → Copiar ID do usuário
DISCORD_OWNER_ID=

# ─── Agendamento ──────────────────────────────────────────────────────────────
# Horário do disparo da daily (sintaxe cron: MINUTO HORA * * DIAS)
# Padrão: 09h30 de segunda a sexta
STANDUP_TIME=30 9 * * 1-5

# Minutos após o disparo para encerrar o prazo e enviar ao ClickUp automaticamente
DEADLINE_MINUTES=30

# Fuso horário IANA
TIMEZONE=America/Sao_Paulo

# ─── ClickUp ──────────────────────────────────────────────────────────────────
# Token de API — ClickUp → avatar → Configurações → Apps → API Token
CLICKUP_API_KEY=

# ID do workspace — visível na URL: app.clickup.com/{WORKSPACE_ID}/...
CLICKUP_WORKSPACE_ID=

# ID do documento onde as páginas de daily serão criadas
# Abra o doc e copie da URL: app.clickup.com/{ws}/docs/{DOC_ID}-...
CLICKUP_DOC_ID=

# ─── Armazenamento (opcional) ─────────────────────────────────────────────────
# Diretório onde os arquivos JSON de dados são salvos (padrão: ./data)
# DATA_DIR=./data
